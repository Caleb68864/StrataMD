# Auto-generated by forge-factory on first run.
# Edit freely — the factory only writes this file when it is missing.

# Default: let git decide based on content.
* text=auto

# Force LF for files that break under CRLF.
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf
*.py        text eol=lf
*.pyi       text eol=lf
Makefile    text eol=lf
makefile    text eol=lf
*.mk        text eol=lf

# Force CRLF for Windows-native scripts.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Common binaries — never normalize, never diff as text.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.7z        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.mp3       binary
*.mp4       binary
*.wav       binary
*.webm      binary
*.webp      binary
*.dll       binary
*.exe       binary
*.so        binary
*.dylib     binary
